---
import BlogPostCard from '../../components/BlogPostCard.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getSortedAndFilteredPosts } from '../../utils/blog';

const posts = await getSortedAndFilteredPosts(true, 'es');
const featuredIds = new Set([
  'surrender-to-the-light-of-your-own-being',
  'the-empty-cup-and-the-living-water',
  'the-light-does-not-need-all-colors-to-become-one',
]);
const featuredPosts = posts.filter((post) => featuredIds.has(post.data.contentId));
---

<SiteLayout
  locale="es"
  alternateUrl="/"
  title="Inicio | Pondering Silver"
  description="Reflexiones, transmisiones y acompañamiento espiritual en español para volver a escuchar tu propia sabiduría interior."
>
  <header class="space-y-6 text-center">
    <span class="inline-flex items-center justify-center rounded-full bg-purple-100 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-purple-700">
      Una invitación a volver hacia dentro
    </span>
    <h1 class="text-3xl font-bold text-gray-900 sm:text-5xl">Pondering Silver en español</h1>
    <p class="mx-auto max-w-3xl text-base leading-relaxed text-gray-600 sm:text-lg">
      Reflexiones, transmisiones y espacios de acompañamiento para quienes exploran la consciencia, la vida interior y
      el misterio de ser plenamente humanos.
    </p>
    <div class="flex flex-wrap justify-center gap-3 text-sm text-purple-700">
      <a href="/es/services" class="inline-flex items-center gap-2 rounded-full border border-purple-200 bg-white px-4 py-2 font-medium transition hover:border-purple-400 hover:text-purple-800">
        Acompañamiento
        <span aria-hidden="true">→</span>
      </a>
      <a href="/es/blog" class="inline-flex items-center gap-2 rounded-full border border-purple-200 bg-white px-4 py-2 font-medium transition hover:border-purple-400 hover:text-purple-800">
        Explorar el blog
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </header>

  <section class="mt-14 grid gap-5 md:grid-cols-3">
    <a href="/es/services" class="rounded-2xl border border-purple-100 bg-white p-6 shadow-xs transition hover:border-purple-300 hover:shadow-md">
      <p class="text-xs font-semibold uppercase tracking-wide text-purple-700">Servicios</p>
      <h2 class="mt-3 text-xl font-semibold text-gray-900">Claridad del Alma</h2>
      <p class="mt-3 text-sm leading-relaxed text-gray-600">
        Un espacio individual para hablar con honestidad, reconocer patrones y volver a escuchar tu propia guía.
      </p>
    </a>
    <a href="/resume-es" class="rounded-2xl border border-purple-100 bg-white p-6 shadow-xs transition hover:border-purple-300 hover:shadow-md">
      <p class="text-xs font-semibold uppercase tracking-wide text-purple-700">Trayectoria profesional</p>
      <h2 class="mt-3 text-xl font-semibold text-gray-900">Currículum técnico</h2>
      <p class="mt-3 text-sm leading-relaxed text-gray-600">
        Experiencia como desarrollador sénior full-stack con Angular, .NET y Azure.
      </p>
    </a>
    <a href="/freelance-es" class="rounded-2xl border border-purple-100 bg-white p-6 shadow-xs transition hover:border-purple-300 hover:shadow-md">
      <p class="text-xs font-semibold uppercase tracking-wide text-purple-700">Trabajo independiente</p>
      <h2 class="mt-3 text-xl font-semibold text-gray-900">Desarrollo freelance</h2>
      <p class="mt-3 text-sm leading-relaxed text-gray-600">
        Apoyo sénior para aplicaciones web complejas, modernización frontend y entregas full-stack.
      </p>
    </a>
  </section>

  {featuredPosts.length > 0 && (
    <section class="mt-16 space-y-6">
      <div class="flex flex-col items-center gap-2 text-center">
        <h2 class="text-2xl font-semibold text-gray-900">Reflexiones para comenzar</h2>
        <p class="max-w-2xl text-sm leading-relaxed text-gray-600">
          Tres entradas que ofrecen distintos caminos hacia el corazón de Pondering Silver.
        </p>
      </div>
      <div class="grid gap-6 md:grid-cols-2">
        {featuredPosts.map((post) => <BlogPostCard post={post} />)}
      </div>
      <div class="text-center">
        <a
          href="/es/blog"
          class="inline-flex items-center gap-2 rounded-full border border-purple-300 bg-purple-50 px-4 py-2 text-sm font-semibold text-purple-700 transition hover:border-purple-400 hover:bg-purple-100"
        >
          Ver todas las publicaciones
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>
  )}
</SiteLayout>

