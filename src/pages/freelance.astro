---
import BaseHead from '../components/BaseHead.astro';
import { resumeData, experienceTotal } from '../data/resume';

const title = 'Senior Freelance Angular and .NET Developer | Donald Clements';
const description =
  'Senior freelance Angular and .NET developer for complex web apps. I build workflow-heavy UIs, modernize enterprise frontends, and connect Angular apps to well-structured .NET and Azure backends.';

const contactLinks = [
  {
    label: 'Email',
    value: resumeData.contact.email,
    href: `mailto:${resumeData.contact.email}?subject=Freelance%20project%20inquiry`,
  },
  {
    label: 'WhatsApp',
    value: resumeData.contact.whatsapp,
    href: resumeData.contact.whatsappLink.replace('frontend%20opportunity', 'freelance%20project'),
  },
  {
    label: 'LinkedIn',
    value: 'donald-duane-clements',
    href: resumeData.contact.linkedin,
  },
];

const proofPoints = [
  {
    value: experienceTotal,
    label: 'years of production software experience',
  },
  {
    value: 'Angular 6–19',
    label: 'Angular versions shipped in production',
  },
  {
    value: '.NET + Azure',
    label: 'full-stack and cloud delivery',
  },
];

const services = [
  {
    title: 'Complex Angular Workflows',
    summary:
      'I design and build Angular interfaces with complex business rules while keeping them clear and usable for the people who rely on them.',
    details: [
      'Reactive state management, form validation, and multi-step workflow orchestration',
      'Dashboards, advanced search, custom data grids, workspaces, and internal operations tools',
      'Angular Signals, RxJS, TypeScript, Sass, component libraries, and design-system alignment',
    ],
  },
  {
    title: 'Incremental Frontend Modernization',
    summary:
      'I modernize legacy Angular frontends and clean up hard-to-maintain code without forcing a rewrite or slowing your team down.',
    details: [
      'Angular version upgrades, phased refactoring plans, and gradual adoption of modern patterns',
      'Performance fixes for slow dashboards, data-heavy screens, and long-lived enterprise views',
      'Component cleanup, code review standards, and documentation your team will actually use',
    ],
  },
  {
    title: 'Full-Stack .NET & Azure Delivery',
    summary:
      'Full-stack feature work when your Angular UI needs APIs, data, cloud infrastructure, or backend support.',
    details: [
      '.NET Core, C#, Web API, Entity Framework Core, Azure Functions, SQL Server, and MongoDB',
      'REST API design, backend feature ownership, database schema work, and environment troubleshooting',
      'Test coverage, Azure DevOps pipelines, CI/CD setup, and release support',
    ],
  },
  {
    title: 'Technical Discovery & Rescue',
    summary:
      'For projects where the hardest part is untangling business logic, edge cases, legacy bugs, and unclear stakeholder expectations.',
    details: [
      'Requirement gap analysis, architecture planning, implementation plans, and early risk notes',
      'Root-cause debugging for stubborn UI, state, API, and integration issues',
      'Developer mentoring, onboarding support, PR review, and senior engineering perspective for lean teams',
    ],
  },
];

const engagementModels = [
    {
        title: 'Scoped build',
        detail:
            'Best when you have a clearly scoped feature, dashboard, internal tool, migration, or integration that needs senior ownership from planning to handoff.',
    },
    {
        title: 'Fractional frontend lead',
        detail:
            'Best for teams that need Angular architecture guidance, steady code review, mentoring, and hands-on delivery without hiring full-time.',
    },
    {
        title: 'Technical audit',
        detail:
            'Best when your codebase has fragile state, performance problems, unclear APIs, or requirements that need to become an executable plan.',
    },
    {
        title: 'Custom application',
        detail:
            'Best for founders and businesses that need to turn an idea or prototype into a production-ready application.',
    },
];

const exampleEngagements = [
  {
    title: 'Diagnostic sprint',
    duration: '1–2 days',
    bestFor: 'When your Angular app is stuck, the requirements are unclear, or you need a plan from a senior engineer before spending real development budget.',
    outputs: [
      'Focused review of your codebase, state management, and requirements',
      'Clear notes on root causes, technical debt, risks, assumptions, and tradeoffs',
      'A prioritized implementation plan your team can start using right away',
    ],
  },
  {
    title: 'Feature delivery sprint',
    duration: '1–2 weeks',
    bestFor: 'A specific module, dashboard, workflow screen, integration slice, or modernization step that needs senior frontend ownership.',
    outputs: [
      'Production-ready Angular/TypeScript implementation',
      'API contract coordination and backend support where needed',
      'Reviewable PRs, handoff notes, and scoped follow-up recommendations',
    ],
  },
  {
    title: 'Architecture and build cycle',
    duration: '3–4 weeks',
    bestFor: 'A larger Angular application slice, MVP foundation, migration phase, or project rescue that needs planning, delivery, and deployment discipline.',
    outputs: [
      'Module structure, state strategy, workflow design, and implementation',
      'CI/CD, hosting, auth, database, or cloud integration support when in scope',
      'Clean source handoff with documentation and full ownership staying with your team',
    ],
  },
];

const ownershipPromise = [
  'I work in your repositories, project management systems, cloud accounts, and deployment pipeline wherever practical.',
  'You retain source code, infrastructure ownership, billing control, credentials, and deployment access from day one.',
  'No proprietary lock-in, no hidden dependency on my private tooling, and no unclear ownership. Important decisions are documented so your team is not dependent on tribal knowledge.',
];

const billingPrinciples = [
  {
    title: 'Fixed-price milestones for known scope',
    detail:
      'Best when the outcome is specific: a feature, audit, migration slice, workflow screen, or deployment cycle with clear acceptance criteria.',
  },
  {
    title: 'Hourly or fractional support for discovery-heavy work',
    detail:
      'Best when the codebase is unknown, the requirements are still moving, or the work needs ongoing architecture, review, and delivery judgment.',
  },
  {
    title: 'New scope called out separately',
    detail:
      'If the project expands, I will call that out clearly and separate new scope from the original agreement instead of burying it in vague revisions.',
  },
];

const processSteps = [
  {
    title: 'Clarify the outcome',
    detail:
      'We define what success looks like, what constraints matter, and which decisions need to be made before implementation starts.',
  },
  {
    title: 'Map the work',
    detail:
      'I translate requirements into a technical plan with assumptions, dependencies, risks, and a delivery path your team can reason about.',
  },
  {
    title: 'Build in small iterations',
    detail:
      'I ship incrementally, communicate tradeoffs early, document important decisions, and keep the work easy to review.',
  },
  {
    title: 'Handoff cleanly',
    detail:
      'You get maintainable code, deployment notes where useful, and enough context for your team to extend the work confidently.',
  },
];

const goodFit = [
  'You have a serious Angular, TypeScript, or .NET system that needs calm senior ownership.',
  'Your project involves dense workflow logic, operational screens, integrations, or business rules.',
  'You value clear communication, low-drama delivery, and maintainable code over rushing for the sake of appearances.',
  'You need someone who can work async, remote, and independently while still collaborating well with product and engineering.',
];

const projectKinds = [
  'Internal operations tools',
  'Enterprise dashboards',
  'Workflow-heavy Angular apps',
  'Angular modernization',
  'API-backed frontend features',
  'Technical audits',
  'Bug hunts and RCA',
  'Prototype-to-production hardening',
];

const primaryExperience = resumeData.experiences[0];
const primaryRole = primaryExperience.roles[0];
const primaryExperienceRange = '2018 - 2025';
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead title={title} description={description} noImage={true} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      }

      .freelance-main {
        width: 100%;
        max-width: none;
        margin: 0;
        padding: 0;
      }

      .freelance-main [id] {
        scroll-margin-top: 8rem;
      }

      @media print {
        html,
        body {
          background: white;
          color: #0f172a;
        }

        @page {
          margin: 0.55in;
          size: letter;
        }

        * {
          -webkit-print-color-adjust: exact !important;
          print-color-adjust: exact !important;
        }

        .print-hidden {
          display: none !important;
        }
      }
    </style>
  </head>
  <body class="bg-slate-50 text-slate-950 antialiased">
    <header class="sticky top-0 z-50 border-b border-slate-200 bg-white/95 shadow-xs backdrop-blur">
      <div class="mx-auto flex max-w-6xl flex-col gap-4 px-4 py-5 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
        <a href="/freelance/" class="text-sm font-bold uppercase tracking-[0.24em] text-slate-950">
          Donald Clements
        </a>
        <nav aria-label="Freelance page navigation" class="print-hidden flex flex-wrap gap-x-5 gap-y-2 text-sm font-medium">
          <a class="text-slate-600 hover:text-emerald-700" href="#services">Services</a>
          <a class="text-slate-600 hover:text-emerald-700" href="#proof">Experience</a>
          <a class="text-slate-600 hover:text-emerald-700" href="#engagements">Engagements</a>
          <a class="text-slate-600 hover:text-emerald-700" href="#billing">Billing</a>
          <a class="text-slate-600 hover:text-emerald-700" href="#process">Process</a>
          <a class="text-slate-600 hover:text-emerald-700" href="#contact">Contact</a>
        </nav>
      </div>
    </header>

    <main class="freelance-main">
      <section class="border-b border-slate-200 bg-[linear-gradient(135deg,#f8fafc_0%,#ffffff_45%,#ecfdf5_100%)]">
        <div class="mx-auto grid max-w-6xl gap-10 px-4 py-10 sm:px-6 lg:grid-cols-[minmax(0,1fr)_22rem] lg:items-start lg:px-8 lg:py-16">
          <div class="max-w-3xl">
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-emerald-700">
              Freelance senior Angular and .NET developer
            </p>
            <h1 class="mt-4 text-3xl font-extrabold leading-tight tracking-normal text-slate-950 sm:text-5xl lg:text-6xl">
              Senior Angular and .NET development for complex web apps.
            </h1>
            <p class="mt-6 max-w-2xl text-base leading-7 text-slate-700 sm:text-lg sm:leading-8">
                I help product and engineering teams build and improve Angular and .NET applications with complex workflows, API-backed features, and business rules that need to be handled carefully. I’m comfortable working across the frontend, the backend, and the practical details that make software hold up in production.
            </p>
            <div class="print-hidden mt-8 flex flex-col gap-3 sm:flex-row">
              <a
                href={`mailto:${resumeData.contact.email}?subject=Freelance%20project%20inquiry`}
                class="inline-flex min-h-11 items-center justify-center rounded-md bg-slate-950 px-5 py-3 text-sm font-semibold text-white shadow-xs transition hover:bg-slate-800 focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2"
              >
                Start a project conversation
              </a>
              <a
                href="/resume/"
                class="inline-flex min-h-11 items-center justify-center rounded-md border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-800 shadow-xs transition hover:border-emerald-500 hover:text-emerald-700 focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2"
              >
                View technical resume
              </a>
            </div>
          </div>

          <aside id="contact" class="rounded-lg border border-slate-200 bg-white p-6 shadow-xs">
            <p class="text-sm font-bold uppercase tracking-[0.18em] text-slate-500">Availability</p>
            <p class="mt-3 text-base font-semibold text-slate-950">
              Remote freelance, contract, and fractional support
            </p>
            <p class="mt-2 text-sm leading-6 text-slate-600">
                Based out of Texas, US. Available for scoped feature work, technical audits, frontend modernization, and part-time support for teams that need experienced Angular/.NET help.
            </p>

            <div class="mt-6 space-y-3">
              {contactLinks.map((link) => (
                <a
                  href={link.href}
                  target={link.label === 'Email' ? undefined : '_blank'}
                  rel={link.label === 'Email' ? undefined : 'noopener noreferrer'}
                  class="group block rounded-md border border-slate-200 bg-slate-50 px-4 py-3 transition hover:border-emerald-400 hover:bg-white"
                >
                  <span class="block text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">{link.label}</span>
                  <span class="mt-1 block break-words text-sm font-semibold text-slate-900 group-hover:text-emerald-700">{link.value}</span>
                </a>
              ))}
            </div>

            <div class="mt-6 border-t border-slate-200 pt-5 text-sm text-slate-600">
              Preferred first step: send a short note with the project goal, timeline, stack, and what needs to change. I typically respond within one business day.
            </div>
          </aside>
        </div>
      </section>

      <section class="border-b border-slate-200 bg-white">
        <div class="mx-auto grid max-w-6xl gap-3 px-4 py-6 sm:grid-cols-3 sm:px-6 lg:px-8">
          {proofPoints.map((point) => (
            <div class="rounded-lg border border-slate-200 bg-slate-50 p-5">
              <p class="text-2xl font-extrabold tracking-normal text-slate-950">{point.value}</p>
              <p class="mt-1 text-sm leading-5 text-slate-600">{point.label}</p>
            </div>
          ))}
        </div>
      </section>

      <section id="services" class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-700">Services</p>
          <h2 class="mt-3 text-3xl font-extrabold tracking-normal text-slate-950">Where I can help</h2>
          <p class="mt-4 text-base leading-7 text-slate-700">
              I’m most useful on Angular and .NET projects where the hard part is not just writing code, but understanding the rules, workflows, and production constraints behind it. I can help clarify what needs to be built, improve how the frontend is structured, and ship work that your team can maintain after handoff.
          </p>
        </div>

        <div class="mt-10 grid gap-5 md:grid-cols-2">
          {services.map((service) => (
            <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-xs">
              <h3 class="text-lg font-bold text-slate-950">{service.title}</h3>
              <p class="mt-3 text-sm leading-6 text-slate-700">{service.summary}</p>
              <ul class="mt-5 space-y-3 text-sm leading-6 text-slate-700">
                {service.details.map((detail) => (
                  <li class="flex gap-3">
                    <span aria-hidden="true" class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-emerald-500"></span>
                    <span>{detail}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section id="proof" class="border-y border-slate-200 bg-slate-100">
        <div class="mx-auto grid max-w-6xl gap-10 px-4 py-16 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:px-8">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-700">Recent experience</p>
            <h2 class="mt-3 text-3xl font-extrabold tracking-normal text-slate-950">Experience with large enterprise systems.</h2>
            <p class="mt-4 text-base leading-7 text-slate-700">
                Most of my recent work has been inside a global logistics and materials-management platform for a major oilfield services client. That work involved large codebases, mono repos, demanding workflows, distributed teams and stakeholders, and production systems where correctness mattered.
            </p>
          </div>

          <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-xs">
            <!-- Company & Overall Range -->
            <div class="border-b border-slate-100 pb-4">
              <p class="text-xs font-bold uppercase tracking-[0.16em] text-slate-500">{primaryExperience.company}</p>
              <h3 class="mt-1.5 text-lg font-bold text-slate-950">7-Year Full-Stack Progression</h3>
              <p class="text-sm font-semibold text-emerald-700">{primaryExperienceRange}</p>
            </div>

            <!-- Timeline Progression -->
            <div class="mt-6 space-y-6 relative border-l-2 border-slate-100 pl-4 ml-2">
              <!-- Phase 3 -->
              <div class="relative">
                <span class="absolute -left-[23px] top-1 h-3 w-3 rounded-full border-2 border-white bg-emerald-500 ring-4 ring-emerald-50"></span>
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1">
                  <h4 class="font-bold text-slate-950 text-sm">{primaryExperience.roles[0].title}</h4>
                  <span class="text-xs font-semibold text-slate-500 whitespace-nowrap">{primaryExperience.roles[0].period}</span>
                </div>
                <p class="mt-2 text-xs leading-5 text-slate-600">
                  Co-led global logistics UI modernization (Angular 11–19). Designed core reactive workspaces, dynamic form validations, and Signals state patterns while coordinating distributed delivery teams.
                </p>
              </div>

              <!-- Phase 2 -->
              <div class="relative">
                <span class="absolute -left-[23px] top-1.5 h-3 w-3 rounded-full border-2 border-white bg-sky-500 ring-4 ring-sky-50"></span>
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1">
                  <h4 class="font-bold text-slate-950 text-sm">{primaryExperience.roles[1].title}</h4>
                  <span class="text-xs font-semibold text-slate-500 whitespace-nowrap">{primaryExperience.roles[1].period}</span>
                </div>
                <p class="mt-2 text-xs leading-5 text-slate-600">
                  Designed backend microservices and self-healing Azure Functions to bridge legacy and modern systems. Established SRE observability patterns (KQL alerts) to automate fault detection.
                </p>
              </div>

              <!-- Phase 1 -->
              <div class="relative">
                <span class="absolute -left-[23px] top-1.5 h-3 w-3 rounded-full border-2 border-white bg-slate-300 ring-4 ring-slate-50"></span>
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1">
                  <h4 class="font-bold text-slate-950 text-sm">{primaryExperience.roles[2].title}</h4>
                  <span class="text-xs font-semibold text-slate-500 whitespace-nowrap">{primaryExperience.roles[2].period}</span>
                </div>
                <p class="mt-2 text-xs leading-5 text-slate-600">
                  Transitioned legacy workflows to a web-based logistics platform. Built backend APIs (.NET Framework/Core) and initial Angular 6+ frontend modules.
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="engagements" class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-700">Engagement examples</p>
          <h2 class="mt-3 text-3xl font-extrabold tracking-normal text-slate-950">Practical ways to bring in senior support</h2>
          <p class="mt-4 text-base leading-7 text-slate-700">
            These are starting points, not rigid packages. They help scope the work, set expectations, and decide whether fixed-price milestones or hourly support make more sense.
          </p>
        </div>

        <div class="mt-10 grid gap-5 lg:grid-cols-3">
          {exampleEngagements.map((engagement) => (
            <article class="flex min-h-full flex-col rounded-lg border border-slate-200 bg-white p-6 shadow-xs">
              <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between lg:flex-col lg:items-start">
                <h3 class="text-lg font-bold text-slate-950">{engagement.title}</h3>
                <span class="inline-flex w-fit rounded-md border border-emerald-200 bg-emerald-50 px-3 py-1 text-xs font-bold uppercase tracking-[0.12em] text-emerald-700">
                  {engagement.duration}
                </span>
              </div>
              <p class="mt-4 text-sm leading-6 text-slate-700">{engagement.bestFor}</p>
              <div class="mt-5 border-t border-slate-200 pt-5">
                <p class="text-xs font-bold uppercase tracking-[0.16em] text-slate-500">Typical outputs</p>
                <ul class="mt-3 space-y-3 text-sm leading-6 text-slate-700">
                  {engagement.outputs.map((output) => (
                    <li class="flex gap-3">
                      <span aria-hidden="true" class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-emerald-500"></span>
                      <span>{output}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </article>
          ))}
        </div>

        <div class="mt-10 grid gap-10 lg:grid-cols-[1fr_1fr]">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-700">Relationship models</p>
            <h2 class="mt-3 text-3xl font-extrabold tracking-normal text-slate-950">How we can work together</h2>
            <div class="mt-8 grid gap-4">
              {engagementModels.map((model) => (
                <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-xs">
                  <h3 class="text-base font-bold text-slate-950">{model.title}</h3>
                  <p class="mt-2 text-sm leading-6 text-slate-700">{model.detail}</p>
                </article>
              ))}
            </div>
          </div>

          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-700">Project fit</p>
            <h2 class="mt-3 text-3xl font-extrabold tracking-normal text-slate-950">Best fit when the work is specific and important</h2>
            <ul class="mt-8 space-y-3 text-sm leading-6 text-slate-700">
              {goodFit.map((fit) => (
                <li class="flex gap-3 rounded-lg border border-slate-200 bg-white p-4 shadow-xs">
                  <span aria-hidden="true" class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-amber-500"></span>
                  <span>{fit}</span>
                </li>
              ))}
            </ul>
            <p class="mt-6 text-sm leading-6 text-slate-500">
              Less of a fit for: simple marketing sites, mobile-native apps, or projects that need a dedicated designer more than senior application engineering.
            </p>
          </div>
        </div>
      </section>

      <section id="billing" class="border-y border-slate-200 bg-white">
        <div class="mx-auto grid max-w-6xl gap-6 px-4 py-16 sm:px-6 lg:grid-cols-[1fr_1fr] lg:px-8">
          <article class="rounded-lg border border-slate-200 bg-slate-950 p-6 text-white shadow-xs sm:p-8">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-300">Client-first ownership</p>
            <h2 class="mt-3 text-3xl font-extrabold tracking-normal">Your code, your accounts, your control.</h2>
            <p class="mt-4 text-base leading-7 text-slate-300">
              For new builds and deployment work, I prefer to configure the project inside your infrastructure instead of making you depend on mine.
            </p>
            <ul class="mt-6 space-y-4 text-sm leading-6 text-slate-200">
              {ownershipPromise.map((promise) => (
                <li class="flex gap-3">
                  <span aria-hidden="true" class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-emerald-300"></span>
                  <span>{promise}</span>
                </li>
              ))}
            </ul>
          </article>

          <article class="rounded-lg border border-slate-200 bg-slate-50 p-6 shadow-xs sm:p-8">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-700">Billing and scope</p>
            <h2 class="mt-3 text-3xl font-extrabold tracking-normal text-slate-950">Clear scope makes projects easier to manage.</h2>
            <p class="mt-4 text-base leading-7 text-slate-700">
              I’m comfortable with fixed-price work when the boundaries are clear. For unknown systems, I usually recommend discovery first so the larger estimate is grounded instead of guessed.
            </p>
            <div class="mt-6 grid gap-4">
              {billingPrinciples.map((principle) => (
                <div class="rounded-lg border border-slate-200 bg-white p-4">
                  <h3 class="text-base font-bold text-slate-950">{principle.title}</h3>
                  <p class="mt-2 text-sm leading-6 text-slate-700">{principle.detail}</p>
                </div>
              ))}
            </div>
          </article>
        </div>
      </section>

      <section id="process" class="border-y border-slate-200 bg-white">
        <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
          <div class="max-w-3xl">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-700">Process</p>
            <h2 class="mt-3 text-3xl font-extrabold tracking-normal text-slate-950">Simple process, clear communication</h2>
          </div>

          <div class="mt-10 grid gap-4 md:grid-cols-4">
            {processSteps.map((step, index) => (
              <article class="rounded-lg border border-slate-200 bg-slate-50 p-5">
                <p class="text-sm font-extrabold text-emerald-700">{String(index + 1).padStart(2, '0')}</p>
                <h3 class="mt-4 text-base font-bold text-slate-950">{step.title}</h3>
                <p class="mt-2 text-sm leading-6 text-slate-700">{step.detail}</p>
              </article>
            ))}
          </div>
          <p class="mt-6 max-w-3xl text-sm leading-6 text-slate-700">
            I provide regular progress updates through your preferred channels, whether that is Slack, Teams, email, GitHub, Azure DevOps, or whatever your team already uses.
          </p>
        </div>
      </section>

      <section class="mx-auto grid max-w-6xl gap-10 px-4 py-16 sm:px-6 lg:grid-cols-[0.85fr_1.15fr] lg:px-8">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-700">Capabilities</p>
          <h2 class="mt-3 text-3xl font-extrabold tracking-normal text-slate-950">The stack I work with</h2>
          <p class="mt-4 text-base leading-7 text-slate-700">
            I don’t need a perfect greenfield setup to be useful. I’m used to mature enterprise environments, mixed frontend and backend ownership, and real production constraints.
          </p>
          <div class="mt-8 flex flex-wrap gap-2">
            {projectKinds.map((kind) => (
              <span class="rounded-md border border-slate-200 bg-white px-3 py-2 text-xs font-semibold uppercase tracking-[0.12em] text-slate-700 shadow-xs">
                {kind}
              </span>
            ))}
          </div>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          {resumeData.skills.map((category) => (
            <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-xs">
              <h3 class="text-sm font-bold uppercase tracking-[0.16em] text-slate-500">{category.title}</h3>
              <ul class="mt-4 space-y-2 text-sm leading-6 text-slate-700">
                {category.items.map((item) => (
                  <li class="flex gap-3">
                    <span aria-hidden="true" class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-slate-400"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section class="border-y border-slate-200 bg-slate-100">
        <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
          <div class="max-w-3xl">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-700">Selected projects</p>
            <h2 class="mt-3 text-3xl font-extrabold tracking-normal text-slate-950">Selected public projects</h2>
          </div>

          <div class="mt-10 grid gap-5 md:grid-cols-3">
            {resumeData.projects.map((project) => (
              <article class="flex min-h-full flex-col rounded-lg border border-slate-200 bg-white p-6 shadow-xs">
                <h3 class="text-lg font-bold text-slate-950">{project.title}</h3>
                <p class="mt-3 flex-1 text-sm leading-6 text-slate-700">{project.description}</p>
                <a
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="print-hidden mt-5 inline-flex text-sm font-bold text-emerald-700 hover:text-emerald-900"
                >
                  Visit project
                </a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
        <div class="grid gap-8 rounded-lg border border-slate-200 bg-slate-950 p-6 text-white shadow-xs sm:p-8 lg:grid-cols-[1fr_24rem] lg:items-center">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-300">Next step</p>
            <h2 class="mt-3 text-3xl font-extrabold tracking-normal">Tell me what you are trying to ship, fix, or clarify.</h2>
            <p class="mt-4 text-base leading-7 text-slate-300">
              A useful first message includes your stack, the business goal, the current blocker, timeline, and whether you need implementation, architecture, review, or discovery.
            </p>
          </div>
          <div class="print-hidden grid gap-3">
            <a
              href={`mailto:${resumeData.contact.email}?subject=Freelance%20project%20inquiry`}
              class="inline-flex min-h-11 items-center justify-center rounded-md bg-emerald-400 px-5 py-3 text-sm font-bold text-slate-950 transition hover:bg-emerald-300 focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-emerald-200 focus-visible:ring-offset-2 focus-visible:ring-offset-slate-950"
            >
              Email Donald
            </a>
            <a
              href={resumeData.contact.whatsappLink.replace('frontend%20opportunity', 'freelance%20project')}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex min-h-11 items-center justify-center rounded-md border border-slate-600 px-5 py-3 text-sm font-bold text-white transition hover:border-emerald-300 hover:text-emerald-200 focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-emerald-200 focus-visible:ring-offset-2 focus-visible:ring-offset-slate-950"
            >
              Message on WhatsApp
            </a>
          </div>
        </div>
      </section>
    </main>

    <footer class="border-t border-slate-200 bg-white">
      <div class="mx-auto flex max-w-6xl flex-col gap-3 px-4 py-8 text-sm text-slate-600 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
        <p>Donald Clements — Senior full-stack Angular and .NET web developer</p>
        <div class="print-hidden flex flex-wrap gap-x-5 gap-y-2">
          <a class="font-medium text-slate-700 hover:text-emerald-700" href="/resume/">Resume</a>
          <a class="font-medium text-slate-700 hover:text-emerald-700" href={resumeData.resumePdfUrl} target="_blank" rel="noopener noreferrer">PDF Resume</a>
          <a class="font-medium text-slate-700 hover:text-emerald-700" href="https://github.com/silveranstavern-gmail" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
    </footer>
  </body>
</html>
