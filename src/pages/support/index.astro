---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { books, donationLinks } from '../../data/support';

const featuredBook = books[0];
---

<SiteLayout
  title="Support | Pondering Silver"
  description="Support Pondering Silver through direct giving, books, and future offerings."
>
  <article class="mx-auto flex max-w-5xl flex-col gap-12">
    <header class="space-y-4 text-center">
      <span class="inline-flex items-center justify-center rounded-full bg-purple-100 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-purple-700">
        Support
      </span>
      <h1 class="text-4xl font-bold text-gray-900">Support the Work</h1>
      <p class="mx-auto max-w-3xl text-lg text-gray-600">
        If the writing, tools, music, meditations, or reflections here have met you somewhere real, this page gathers
        the ways you can support what I am building.
      </p>
    </header>

    <section class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
      <div class="rounded-3xl border border-purple-100 bg-white p-8 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-purple-600">Featured Book</p>
        <h2 class="mt-3 text-3xl font-bold text-gray-900">{featuredBook.title}</h2>
        <p class="mt-4 text-gray-700">
          A lyrical, intimate collection on healing, longing, vulnerability, spiritual becoming, and the slow
          transmutation of pain into presence.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href={featuredBook.href}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg bg-purple-600 px-5 py-3 text-sm font-medium text-white shadow-md transition hover:bg-purple-700"
          >
            Buy on Amazon
          </a>
          <a
            href="/support/books"
            class="inline-flex items-center gap-2 rounded-lg border border-purple-200 bg-purple-50 px-5 py-3 text-sm font-medium text-purple-700 transition hover:border-purple-300 hover:bg-purple-100"
          >
            View books
          </a>
        </div>
      </div>

      <a
        href="/support/books"
        class="group overflow-hidden rounded-3xl border border-gray-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-lg"
      >
        <img
          src={featuredBook.image}
          alt={`Cover of ${featuredBook.title}`}
          class="h-full min-h-[320px] w-full object-cover"
          loading="lazy"
        />
      </a>
    </section>

    <section class="space-y-6">
      <div class="space-y-2 text-center">
        <h2 class="text-2xl font-semibold text-gray-900">Direct Support</h2>
        <p class="mx-auto max-w-2xl text-sm text-gray-600">
          Choose the path that feels simplest. These contributions help sustain the writing, recordings, experiments,
          and future offerings still taking shape.
        </p>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        {donationLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-full flex-col rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md"
          >
            <h3 class="text-lg font-semibold text-gray-900">{link.title}</h3>
            <p class="mt-3 text-sm text-gray-600">{link.description}</p>
            <div class="mt-auto pt-5">
              <span class="text-sm font-medium text-purple-600">Open support option</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="rounded-3xl border border-gray-200 bg-white p-8 shadow-sm">
      <div class="flex flex-col gap-5 md:flex-row md:items-center md:justify-between">
        <div>
          <h2 class="text-2xl font-semibold text-gray-900">Books and Future Offerings</h2>
          <p class="mt-2 max-w-2xl text-sm text-gray-600">
            This section will expand over time to include books, downloadable audio, and other things you can buy to
            support the work directly.
          </p>
        </div>
        <a
          href="/support/books"
          class="inline-flex items-center justify-center rounded-lg border border-purple-200 bg-purple-50 px-5 py-3 text-sm font-medium text-purple-700 transition hover:border-purple-300 hover:bg-purple-100"
        >
          Browse books
        </a>
      </div>
    </section>
  </article>
</SiteLayout>
