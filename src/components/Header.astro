---
import { SITE_TITLE } from '../consts';
import { siteUi, type SiteLocale } from '../i18n/site';

interface Props {
	locale?: SiteLocale;
	alternateUrl?: string;
}

const { locale = 'en', alternateUrl } = Astro.props as Props;
const copy = siteUi[locale];
---

<header class="sticky top-0 z-40 bg-white shadow-xs">
	<div class="flex items-center h-16 px-4 sm:px-6">
		<button
			type="button"
			class="flex items-center justify-center w-10 h-10 mr-4 rounded-full text-gray-600 hover:bg-gray-100 focus:outline-hidden focus-visible:ring-2 focus-visible:ring-brand"
			aria-label={copy.menuLabel}
			aria-controls="site-sidebar"
			aria-expanded="false"
			data-sidebar-toggle
		>
			<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<line x1="4" y1="6" x2="20" y2="6" />
				<line x1="4" y1="12" x2="20" y2="12" />
				<line x1="4" y1="18" x2="20" y2="18" />
			</svg>
		</button>
		<a href={copy.homePath} class="text-3xl font-semibold tracking-wide text-gray-900 transition-colors duration-200 hover:text-gray-700">
			<span class="inline-block pr-1 -translate-y-[0.2em]">P</span>
			<span class="inline-block">s</span>
			<span class="ml-3 text-base font-medium uppercase tracking-[0.3em] text-gray-500 hidden sm:inline">{SITE_TITLE}</span>
		</a>
		{alternateUrl && (
			<a
				href={alternateUrl}
				hreflang={locale === 'en' ? 'es' : 'en'}
				lang={locale === 'en' ? 'es' : 'en'}
				class="ml-auto inline-flex min-h-9 items-center justify-center rounded-full border border-purple-200 bg-purple-50 px-3 text-xs font-bold uppercase tracking-[0.16em] text-purple-700 transition hover:border-purple-400 hover:bg-purple-100 hover:text-purple-900"
				aria-label={copy.languageLabel}
			>
				{copy.languageCode}
			</a>
		)}
	</div>
</header>
