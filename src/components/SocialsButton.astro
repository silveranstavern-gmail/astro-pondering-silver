---
import { Icon } from 'astro-icon/components';
---

<button
  type="button"
  class="flex flex-col items-center transition-transform duration-200"
  data-overlay-trigger="socials"
  aria-haspopup="dialog"
  aria-controls="site-overlay"
>
  <div class="relative h-12 w-12">
    <div class="relative z-10 flex h-full w-full items-center justify-center rounded-full bg-purple-600 text-white shadow-lg transition-transform duration-200 hover:scale-105 hover:bg-purple-700">
      <Icon name="heroicons:users-solid" class="h-6 w-6" aria-hidden="true" />
    </div>
  </div>
  <span class="mt-1 text-xs font-medium text-gray-700 sm:mt-2 sm:text-sm">Socials</span>
</button>
