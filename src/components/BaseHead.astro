---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/default.jpg';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

interface Props {
	title?: string;
	description?: string;
	image?: ImageMetadata;
	noImage?: boolean;
}

const { title = SITE_TITLE, description = SITE_DESCRIPTION, image, noImage = false } = Astro.props as Props;
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : Astro.url;
const effectiveImage = noImage ? undefined : (image ?? FallbackImage);
const ogImageURL = effectiveImage ? new URL(effectiveImage.src, Astro.site ?? Astro.url) : undefined;
const normalizedPathname = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const llmTextHref = normalizedPathname === '/resume/'
	? '/resume/llm.txt'
	: normalizedPathname.startsWith('/blog/') && normalizedPathname !== '/blog/'
		? `${normalizedPathname}llm.txt`
		: undefined;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="sitemap" href="/sitemap-index.xml" />
{Astro.site && (
	<link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href={new URL('rss.xml', Astro.site)} />
)}
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

{llmTextHref && <link rel="alternate" type="text/plain" title="LLM-ready text" href={llmTextHref} />}

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{ogImageURL && <meta property="og:image" content={ogImageURL} />}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
{ogImageURL && <meta property="twitter:image" content={ogImageURL} />}

<!-- Analytics -->
<script defer src="https://cloud.umami.is/script.js" data-website-id="6ee9553a-9eb0-4a62-a3b7-f9c9bca6bf8e"></script>

